{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noEmit": true,
    "skipLibCheck": true,
    "verbatimModuleSyntax": true,
    "jsx": "react-jsx",
    "jsxImportSource": "chibireact",
    "baseUrl": ".",
    "paths": {
      "chibireact": ["packages/chibireact/src/index.ts"],
      "chibireact/*": ["packages/chibireact/src/*"],
      "chibireact-dom/client": ["packages/chibireact-dom/src/client.ts"],
      "@chibireact/reconciler": ["packages/reconciler/src/index.ts"],
      "@chibireact/scheduler": ["packages/scheduler/src/index.ts"]
    },
    "types": ["node", "vitest/globals"]
  },
  "include": [
    "packages/**/*.ts",
    "packages/**/*.tsx",
    "examples/**/*.ts",
    "examples/**/*.tsx",
    "book/impls/**/*.ts",
    "tests/**/*.ts",
    "vite.config.ts",
    "vitest.config.ts",
    "playwright.config.ts"
  ],
  "exclude": ["node_modules", "book/online-book/.vitepress/dist"]
}
