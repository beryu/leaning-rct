{
  "name": "chibireact-workspace",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.13.1",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "vitepress dev book/online-book",
    "book:build": "vitepress build book/online-book",
    "book:preview": "vitepress preview book/online-book",
    "play": "pnpm --filter @chibireact/playground dev",
    "build": "pnpm -r --if-present build && pnpm book:build",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint:text": "textlint book/online-book/src README.md CONTRIBUTING.md",
    "check:links": "node tools/check-links.mjs",
    "check": "pnpm format:check && pnpm lint && pnpm typecheck && pnpm test && pnpm lint:text && pnpm check:links && pnpm book:build"
  },
  "devDependencies": {
    "@eslint/js": "^9.31.0",
    "@playwright/test": "^1.54.1",
    "@textlint-ja/textlint-rule-preset-ai-writing": "^1.6.0",
    "@types/node": "^24.0.14",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^9.31.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^16.3.0",
    "jsdom": "^26.1.0",
    "prettier": "^3.6.2",
    "textlint": "^14.8.4",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.37.0",
    "vite": "^7.0.5",
    "vitepress": "^1.6.4",
    "vitest": "^3.2.4",
    "vue": "^3.5.18"
  }
}
